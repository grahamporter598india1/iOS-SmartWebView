name: Build Kiosk Webview App

on:
  workflow_dispatch: # Allows manual trigger click within browser panel

jobs:
  build:
    runs-on: macos-latest # Fires up a clean macOS virtual environment instance
    steps:
    - name: Checkout Source Code
      uses: actions/checkout@v4 # Clones repository into cloud engine container

    - name: Select Core Xcode Environment
      uses: maxim-lobanov/setup-xcode@v1
      with:
        xcode-version: 'latest-stable' # Leverages up-to-date apple tools arrays

    - name: Compile and Archive Xcode App Package
      run: |
        xcodebuild -project "iOS-SmartWebView.xcodeproj" \
                   -scheme "iOS-SmartWebView" \
                   -configuration Release \
                   -sdk iphoneos \
                   CODE_SIGNING_ALLOWED=NO \
                   CODE_SIGNING_REQUIRED=NO \
                   clean archive -archivePath $PWD/build/KioskApp.xcarchive

    - name: Construct Final Unsigned IPA File Package Container
      run: |
        mkdir -p $PWD/build/Payload
        cp -r $PWD/build/KioskApp.xcarchive/Products/Applications/*.app $PWD/build/Payload/
        cd $PWD/build
        zip -r KioskApp.ipa Payload

    - name: Publish Compiled Application Artifact
      uses: actions/upload-artifact@v4 # Uploads build to browser dashboard
      with:
        name: Kiosk-Unsigned-IPA
        path: build/KioskApp.ipa
